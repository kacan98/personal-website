{
  "name": "my-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:dev": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:update-cv-screens": "UPDATE_CV_STORY_SCREENSHOTS=1 playwright test e2e/cv-tailoring.spec.ts",
    "capture:dashboard-screens": "node scripts/capture-dashboard-story-screens.mjs",
    "prepare": "husky",
    "validate-md": "remark data/ --use remark-lint-frontmatter-schema",
    "validate-md:watch": "remark data/ --use remark-lint-frontmatter-schema --watch",
    "validate:projects": "node scripts/validate-projects.mjs",
    "validate:localized-projects": "node scripts/validate-localized-projects.mjs",
    "analyze": "ANALYZE=true npm run build",
    "generate-embeddings": "node scripts/generate-embeddings.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint:fix": "eslint . --fix",
    "check:links": "node scripts/check-links.mjs",
    "check": "npm run validate:projects && npm run validate:localized-projects && npm run type-check && npm run lint && npm run check:links",
    "generate:signature-icons": "node scripts/generate-email-signature-icons.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/urbanist": "^5.2.7",
    "@fontsource/yeseva-one": "^5.2.7",
    "@imgly/background-removal": "^1.7.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/material-nextjs": "^7.3.9",
    "@portabletext/react": "^6.0.3",
    "@react-spring/web": "^10.0.3",
    "@reduxjs/toolkit": "^2.11.2",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.73",
    "@types/three": "^0.183.1",
    "@vercel/speed-insights": "^2.0.0",
    "country-flag-icons": "^1.6.15",
    "diff": "^8.0.4",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "gray-matter": "^4.0.3",
    "gsap": "^3.14.2",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "motion": "^12.38.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-icons": "^5.6.0",
    "react-parallax-tilt": "^1.7.321",
    "react-redux": "^9.2.0",
    "react-to-print": "^3.3.0",
    "react-use": "^17.6.0",
    "recharts": "^3.8.1",
    "styled-components": "^6.3.12",
    "three": "^0.183.2",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar": "^5.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-lint-frontmatter-schema": "^3.15.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run lint:fix --"
    ]
  }
}
