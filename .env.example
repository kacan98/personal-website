# =========================
# Required in production
# =========================
# Used for JWT signing/verification for protected CV auth routes.
# Must be a strong random secret (at least 32 chars), not a placeholder.
JWT_SECRET=replace-me-with-a-strong-random-secret-min-32-chars

# CV admin login password used by /api/auth/login.
# Must be real in production (not placeholder).
CV_ADMIN_PASSWORD=replace-me-with-a-strong-admin-password

# Required for AI endpoints (CV personalization, cover letters, summaries, translations).
# In development/test you can leave this as placeholder if you do not call protected AI endpoints.
OPENAI_API_KEY=sk-REPLACE_ME

# =========================
# Optional / environment-specific
# =========================
# GitHub Repository (for extension downloads)
# Format: username/repository-name
NEXT_PUBLIC_GITHUB_REPO=your-username/personal-website

# Sanity (only if you use Sanity-backed content paths)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_API_READ_TOKEN=

# Database (only required for DB-backed features)
# Format: postgresql://username:password@host:port/database
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/mydb
